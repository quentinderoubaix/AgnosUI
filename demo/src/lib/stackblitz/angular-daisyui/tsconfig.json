{
	"compilerOptions": {
		"rootDir": "src",
		"experimentalDecorators": true,
		"target": "es2022",
		"module": "esnext",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"moduleResolution": "bundler",
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"allowJs": true
	},
	"include": ["src"]
}
