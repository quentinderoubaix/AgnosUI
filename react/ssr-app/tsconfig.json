{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"paths": {
			"@agnos-ui/core/*": ["../../core/src/*"],
			"@agnos-ui/core-bootstrap/*": ["../../core-bootstrap/src/*"],
			"@agnos-ui/react-headless/*": ["../headless/src/*", "../headless/src/generated/*"],
			"@agnos-ui/react/*": ["../lib/src/*", "../lib/src/generated/*"]
		},
		"allowJs": true
	},
	"include": ["src"],
	"files": ["vite.config.ts", "server.js"]
}
